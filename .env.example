# Environment variables for Wong Taek App

# Database URL - PostgreSQL
# Local development from outside Railway should use the public proxy URL.
DATABASE_PUBLIC_URL="postgresql://postgres:password@host:5432/railway"

# Railway runtime can use the internal service URL.
DATABASE_URL="postgresql://postgres:password@postgres.railway.internal:5432/railway"
# IMPORTANT: do not leave this as `file:./prisma/dev.db` from old SQLite configs.

# JWT Secret for authentication
# IMPORTANT: Generate a strong random string for production!
# Use: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Admin auth (production)
ADMIN_JWT_SECRET="your-admin-jwt-secret-change-in-production"
ADMIN_SEED_USERNAME="admin"
ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_PASSWORD="change-me-please"
ADMIN_SEED_NAME="Super Admin"

# Room host token
ROOM_JWT_SECRET="your-room-jwt-secret-change-in-production"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"

# NextAuth / Google Login
NEXTAUTH_URL="http://localhost:3000"
# Prefer a dedicated secret; falls back to JWT_SECRET only if omitted.
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"
NEXT_PUBLIC_GOOGLE_LOGIN_ENABLED="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cloudflare Turnstile (optional but recommended for public forms)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Rate Limiting (optional)
RATE_LIMIT_MAX=100
