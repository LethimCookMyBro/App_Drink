# Environment variables for Wong Taek App

# Database URL - PostgreSQL
# Local development from outside Railway should use the public proxy URL.
DATABASE_PUBLIC_URL="postgresql://postgres:password@host:5432/railway"

# Railway runtime can use the internal service URL.
DATABASE_URL="postgresql://postgres:password@postgres.railway.internal:5432/railway"
# IMPORTANT: do not leave this as `file:./prisma/dev.db` from old SQLite configs.

# JWT Secret for authentication
# IMPORTANT: Generate a unique 32+ character random string for each secret.
# Use: openssl rand -hex 32
JWT_SECRET="replace-with-a-unique-64-char-hex-secret-1"

# Admin auth (production)
ADMIN_JWT_SECRET="replace-with-a-unique-64-char-hex-secret-2"
ADMIN_SEED_USERNAME="admin"
ADMIN_SEED_EMAIL="admin@example.com"
ADMIN_SEED_PASSWORD="change-me-please"
ADMIN_SEED_NAME="Super Admin"

# Room host token
ROOM_JWT_SECRET="replace-with-a-unique-64-char-hex-secret-3"
ROOM_JWT_SECRET_PREVIOUS=""

# App Configuration
# Use the exact public origin that serves the app.
# Turnstile hostname validation compares requests against this host.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"

# NextAuth / Google Login
NEXTAUTH_URL="http://localhost:3000"
# Prefer a dedicated secret distinct from JWT_SECRET.
NEXTAUTH_SECRET="replace-with-a-unique-64-char-hex-secret-4"
# Optional override. If omitted, Google login auto-enables when both
# GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET are configured.
NEXT_PUBLIC_GOOGLE_LOGIN_ENABLED="true"
# Authorized JavaScript origins:
# - http://localhost:3000
# Authorized redirect URIs:
# - http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="put-your-google-client-id-here"
GOOGLE_CLIENT_SECRET="put-your-google-client-secret-here"

# Google Sheets export for Admin
# 1. Create a Google Cloud service account with Sheets API enabled
# 2. Share your target spreadsheet with GOOGLE_SHEETS_CLIENT_EMAIL
# 3. Put the spreadsheet id from the URL here
GOOGLE_SHEETS_SPREADSHEET_ID=""
GOOGLE_SHEETS_CLIENT_EMAIL=""
# Keep newline escapes as \\n when stored in .env
GOOGLE_SHEETS_PRIVATE_KEY=""

# Cloudflare Turnstile (optional but recommended for public forms)
# Register the same hostname as NEXT_PUBLIC_APP_URL in Cloudflare Turnstile.
# This repo verifies both the widget action and the returned hostname.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Rate Limiting (optional)
RATE_LIMIT_MAX=100
DATABASE_MAX_CONNECTIONS=10

# Sensitive field encryption at rest
# Recommended: a secret distinct from JWT secrets
API_ENCRYPTION_KEY="replace-with-a-unique-64-char-hex-secret-5"
